# Supabase — find both under Project Settings → API in the Supabase dashboard.
# Set the same variables in Vercel (Project → Settings → Environment Variables).
#
# The key is the browser-safe public key; all data access is governed by
# Row Level Security. New Supabase projects call it the publishable key
# (sb_publishable_...); older projects call it the anon key. The code accepts
# either variable name, preferring the publishable one.
# Never add the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy alternative, honored if the publishable variable is not set:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Audio Review — hosted natural voice (server-only; never NEXT_PUBLIC).
# When unset, Audio Review falls back to the browser voice.
OPENAI_API_KEY=
# Optional overrides:
# AUDIO_REVIEW_VOICE=nova
# AUDIO_REVIEW_MODEL=tts-1
# AUDIO_REVIEW_DAILY_CHAR_LIMIT=300000
# Editorial AI reviewers (shares OPENAI_API_KEY):
# EDITORIAL_REVIEW_MODEL=gpt-4o
