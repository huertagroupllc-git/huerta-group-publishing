# Supabase — find both under Project Settings → API in the Supabase dashboard.
# Set the same two variables in Vercel (Project → Settings → Environment Variables).
# The anon/publishable key is safe to expose to the browser; all data access
# is governed by Row Level Security. Never add the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>
